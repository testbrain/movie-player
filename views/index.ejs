<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <link rel="icon" href="../uploads/favicon.ico" type="image/x-icon">
    <title>Movie Player - Stream Your Favorite Movies</title>
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: #0a0a0a;
            color: #fff;
            overflow-x: hidden;
        }

        html {
            scroll-behavior: smooth;
        }

        /* Header - fully responsive sticky */
        .header {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            transition: all 0.3s ease;
            background: linear-gradient(180deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.7) 50%, transparent 100%);
        }

        .header.scrolled {
            background: rgba(10, 10, 10, 0.98);
            padding: 8px 0;
            box-shadow: 0 2px 20px rgba(0,0,0,0.6);
            backdrop-filter: blur(2px);
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 24px;
            flex-wrap: wrap;
            gap: 12px;
        }

        /* Logo container - responsive */
        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: transform 0.2s ease;
            flex-shrink: 0;
        }
        
        .logo-wrapper:hover {
            transform: scale(1.02);
        }
        
        .logo-icon {
            font-size: 32px;
            background: linear-gradient(135deg, #e50914 0%, #ff6666 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 8px rgba(229,9,20,0.3));
        }
        
        .logo-text {
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, #e50914 0%, #ff6666 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }
        
        .logo-badge {
            background: rgba(229,9,20,0.2);
            border: 1px solid rgba(229,9,20,0.4);
            border-radius: 30px;
            padding: 2px 8px;
            font-size: 10px;
            font-weight: 700;
            color: #e50914;
            margin-left: 4px;
            letter-spacing: 0.5px;
        }

        /* Nav links responsive */
        .nav-links {
            display: flex;
            gap: 20px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        
        .nav-link {
            color: #e5e5e5;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
            font-size: 0.95rem;
        }
        
        .nav-link:hover {
            color: #e50914;
        }
        
        .add-movie-btn {
            background: #e50914;
            color: white;
            padding: 6px 18px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.2s;
            font-size: 0.85rem;
            white-space: nowrap;
        }
        
        .logout-btn {
            color: #e50914;
            text-decoration: none;
            font-weight: 500;
        }
        
        .welcome-text {
            color: #aaa;
            font-size: 0.8rem;
            white-space: nowrap;
        }

        /* Hero Section - fluid responsive */
        .hero {
            height: 85vh;
            min-height: 560px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.5) 100%), 
                        url('https://res.cloudinary.com/dmtgtme2e/image/upload/v1774607273/poster_tyl4sb.png');
            background-size: cover;
            background-position: center 30%;
            background-repeat: no-repeat;
            transition: all 0.4s ease;
            border-bottom: 3px solid rgba(229,9,20,0.5);
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(0deg, rgba(10,10,10,0.85) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0.2) 100%);
            z-index: 1;
        }

        .hero-content {
            z-index: 3;
            max-width: 900px;
            padding: 0 24px;
            position: relative;
            animation: fadeInUp 0.9s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        .hero h1 {
            font-size: clamp(2rem, 8vw, 4.8rem);
            font-weight: 800;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #ffffff 0%, #e50914 90%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: -0.02em;
        }

        .hero p {
            font-size: clamp(1rem, 4vw, 1.3rem);
            font-weight: 400;
            color: #f0f0f0;
            margin-bottom: 35px;
            line-height: 1.5;
            padding: 0 10px;
        }

        .btn-primary {
            background: #e50914;
            color: white;
            padding: 12px 32px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s;
            cursor: pointer;
            border: none;
            font-family: 'Inter', sans-serif;
            font-size: clamp(0.9rem, 3vw, 1.05rem);
            box-shadow: 0 4px 14px rgba(229,9,20,0.4);
            display: inline-block;
        }

        .btn-primary:hover {
            background: #ff1a2c;
            transform: translateY(-3px);
        }

        /* Main Content - fluid padding */
        .main-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: clamp(20px, 4vw, 40px) clamp(16px, 5vw, 60px) clamp(40px, 6vw, 60px);
            background: #0a0a0a;
            position: relative;
            z-index: 5;
        }

        /* Category Bar with Horizontal Scroll + Dropdown - fully responsive */
        .category-bar {
            background: #111;
            border-radius: 60px;
            padding: 10px 16px;
            margin-bottom: 35px;
            position: sticky;
            top: 70px;
            z-index: 90;
            backdrop-filter: blur(8px);
            background: rgba(15,15,15,0.95);
            border: 1px solid #2a2a2a;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* Horizontal Scrollable Categories - touch friendly */
        .category-scroll-wrapper {
            flex: 1;
            overflow-x: auto;
            overflow-y: hidden;
            scrollbar-width: thin;
            -webkit-overflow-scrolling: touch;
        }

        .category-scroll-wrapper::-webkit-scrollbar {
            height: 4px;
        }

        .category-scroll-wrapper::-webkit-scrollbar-track {
            background: #222;
            border-radius: 10px;
        }

        .category-scroll-wrapper::-webkit-scrollbar-thumb {
            background: #e50914;
            border-radius: 10px;
        }

        .category-scroll {
            display: flex;
            gap: 10px;
            padding: 4px 0;
            white-space: nowrap;
        }

        .cat-chip {
            background: #1f1f2a;
            color: #ddd;
            padding: 7px 18px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.2s ease;
            border: 1px solid #333;
            display: inline-block;
        }

        .cat-chip:hover {
            background: #e50914;
            color: white;
            transform: translateY(-2px);
            border-color: #e50914;
        }

        .cat-chip.active {
            background: #e50914;
            color: white;
            border-color: #e50914;
            box-shadow: 0 2px 12px rgba(229,9,20,0.4);
        }

        /* Circular Dropdown Button - responsive touch target */
        .dropdown-circle-btn {
            width: 44px;
            height: 44px;
            min-width: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e50914, #b00710);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
            box-shadow: 0 2px 8px rgba(229,9,20,0.3);
        }

        .dropdown-circle-btn:hover {
            transform: scale(1.05);
            background: linear-gradient(135deg, #ff1a2c, #e50914);
        }

        .dropdown-circle-btn.active i {
            transform: rotate(180deg);
        }

        .dropdown-circle-btn i {
            color: white;
            font-size: 1.2rem;
            transition: transform 0.3s;
        }

        /* Dropdown Menu - mobile friendly */
        .dropdown-menu {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: min(320px, 85vw);
            max-height: 500px;
            background: #1a1a1f;
            border-radius: 20px;
            border: 1px solid #333;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            overflow: hidden;
            z-index: 1000;
            display: none;
            animation: fadeInUp 0.2s ease;
        }

        .dropdown-menu.show {
            display: block;
        }

        .dropdown-header {
            padding: 14px;
            border-bottom: 1px solid #333;
            background: #111;
        }

        .dropdown-header h4 {
            margin-bottom: 10px;
            color: #e50914;
            font-size: 0.9rem;
        }

        .dropdown-search {
            display: flex;
            align-items: center;
            background: #0a0a0a;
            border: 1px solid #333;
            border-radius: 40px;
            padding: 8px 14px;
            gap: 8px;
        }

        .dropdown-search i {
            color: #888;
            font-size: 0.9rem;
        }

        .dropdown-search input {
            background: transparent;
            border: none;
            color: white;
            font-size: 0.9rem;
            outline: none;
            width: 100%;
        }

        .dropdown-categories {
            max-height: 380px;
            overflow-y: auto;
            padding: 8px 0;
        }

        .dropdown-cat-item {
            padding: 10px 16px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.85rem;
            color: #ddd;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Section Styles */
        .category-section {
            margin-bottom: 45px;
            animation: fadeInUp 0.5s ease forwards;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 18px;
            border-left: 4px solid #e50914;
            padding-left: 18px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .section-title {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
            font-weight: 700;
            color: #fff;
        }

        .section-count {
            color: #a0a0a0;
            font-size: 0.8rem;
            font-weight: 500;
            background: #1f1f1f;
            padding: 4px 12px;
            border-radius: 30px;
        }

        /* Movies Row - horizontal scroll with touch */
        .movies-row {
            position: relative;
            overflow-x: auto;
            overflow-y: hidden;
            white-space: nowrap;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            padding: 8px 0 20px;
            scrollbar-width: thin;
        }

        .movies-row::-webkit-scrollbar {
            height: 6px;
        }

        .movies-row::-webkit-scrollbar-track {
            background: #1e1e1e;
            border-radius: 10px;
        }

        .movies-row::-webkit-scrollbar-thumb {
            background: #e50914;
            border-radius: 10px;
        }

        /* Movie Card - fully responsive */
        .movie-card {
            display: inline-flex;
            flex-direction: column;
            width: clamp(140px, 28vw, 190px);
            margin-right: 16px;
            vertical-align: top;
            transition: transform 0.25s ease;
            cursor: pointer;
            position: relative;
            border-radius: 16px;
        }

        .movie-card:hover {
            transform: translateY(-6px) scale(1.01);
        }

        .movie-poster {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            height: clamp(200px, 40vw, 285px);
            background: linear-gradient(145deg, #222, #111);
            margin-bottom: 12px;
            box-shadow: 0 10px 20px -5px rgba(0,0,0,0.5);
        }

        .movie-poster img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        .movie-card:hover .movie-poster img {
            transform: scale(1.05);
        }

        .movie-poster .placeholder {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: #aaa;
            font-size: 1.8rem;
            background: rgba(0,0,0,0.5);
            width: 100%;
            padding: 12px;
        }

        .priority-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.75);
            backdrop-filter: blur(6px);
            color: #ffd966;
            padding: 4px 8px;
            border-radius: 30px;
            font-size: 0.65rem;
            font-weight: 800;
            z-index: 2;
        }

        .delete-btn {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(229,9,20,0.95);
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 0.65rem;
            font-weight: 700;
            z-index: 2;
            opacity: 0;
            transition: all 0.2s ease;
        }

        .movie-card:hover .delete-btn {
            opacity: 1;
        }

        .delete-btn:hover {
            background: #ff3333;
        }

        .movie-info {
            padding: 0 4px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .movie-name {
            font-size: clamp(0.85rem, 3vw, 1rem);
            font-weight: 600;
            color: #f5f5f5;
            line-height: 1.4;
            white-space: normal;
            word-wrap: break-word;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 42px;
        }

        .tag {
            display: inline-block;
            background: rgba(229,9,14,0.2);
            color: #ff6b6b;
            padding: 3px 10px;
            border-radius: 30px;
            font-size: 0.65rem;
            font-weight: 600;
            width: fit-content;
        }

        .movie-link {
            display: inline-block;
            margin-top: 6px;
            padding: 7px 10px;
            background: linear-gradient(90deg, #e50914, #b00710);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            transition: all 0.2s ease;
            text-align: center;
            width: 100%;
        }

        .movie-link:hover {
            background: linear-gradient(90deg, #ff1a2c, #e50914);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: linear-gradient(135deg, #111, #080808);
            border-radius: 32px;
            border: 1px solid #2a2a2a;
        }

        .footer {
            background: #030303;
            padding: clamp(30px, 5vw, 40px) clamp(16px, 5vw, 60px);
            border-top: 1px solid #222;
            margin-top: 20px;
            text-align: center;
            color: #808080;
            font-size: clamp(0.75rem, 3vw, 0.85rem);
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Tablet and Desktop refinements */
        @media (max-width: 1024px) {
            .category-bar {
                top: 65px;
            }
            .nav-container {
                padding: 10px 20px;
            }
            .nav-links {
                gap: 15px;
            }
        }

        @media (max-width: 768px) {
            .header.scrolled {
                padding: 5px 0;
            }
            .nav-container {
                flex-direction: row;
                justify-content: space-between;
                padding: 10px 16px;
            }
            .nav-links {
                gap: 12px;
            }
            .nav-link, .logout-btn {
                font-size: 0.8rem;
            }
            .add-movie-btn {
                padding: 4px 12px;
                font-size: 0.75rem;
            }
            .welcome-text {
                font-size: 0.7rem;
                white-space: normal;
            }
            .category-bar {
                border-radius: 40px;
                padding: 8px 12px;
                gap: 8px;
            }
            .cat-chip {
                padding: 5px 14px;
                font-size: 0.7rem;
            }
            .dropdown-circle-btn {
                width: 38px;
                height: 38px;
                min-width: 38px;
            }
            .section-header {
                margin-bottom: 14px;
            }
        }

        @media (max-width: 480px) {
            .logo-wrapper {
                gap: 6px;
            }
            .logo-text {
                font-size: 18px;
            }
            .logo-icon {
                font-size: 22px;
            }
            .logo-badge {
                font-size: 7px;
                padding: 1px 5px;
            }
            .nav-links {
                gap: 10px;
            }
            .movie-card {
                width: 140px;
                margin-right: 12px;
            }
            .movie-poster {
                height: 210px;
            }
            .movie-name {
                font-size: 0.8rem;
            }
            .category-bar {
                top: 60px;
            }
            .dropdown-menu {
                width: 90vw;
                right: -10px;
            }
            .hero {
                min-height: 480px;
            }
        }
        
        /* Touch improvements */
        @media (hover: hover) {
            .delete-btn {
                opacity: 0;
            }
        }
        
        @media (hover: none) {
            .delete-btn {
                opacity: 1;
                background: rgba(229,9,20,0.9);
                font-size: 0.6rem;
                padding: 4px 8px;
            }
        }
        
        /* Fix for small height devices */
        @media (max-height: 700px) {
            .hero {
                min-height: 480px;
                height: auto;
                padding: 80px 0 40px;
            }
        }
        
        /* Logo image fallback */
        .logo-img {
            height: 38px;
            width: auto;
            object-fit: contain;
        }
        
        @media (max-width: 480px) {
            .logo-img {
                height: 28px;
            }
        }
    </style>
</head>
<body>
    <header class="header" id="header">
        <div class="nav-container">
            <div class="logo-wrapper" id="logoHomeBtn">
                <!-- <i class="fas fa-play-circle logo-icon"></i> -->
                <img src="../uploads/logo.png" style="height: 35px;"/>
                <div style="display: flex; align-items: baseline; gap: 6px;">
                    <span class="logo-text">MOVIE PLAYER</span>
                    <span class="logo-badge">HD</span>
                </div>
            </div>
            <div class="nav-links">
                <a href="/" class="nav-link">Home</a>
                <a href="#movies-section" class="nav-link" id="browseMoviesLink">Movies</a>
                <% if (user) { %>
                    <% if (user.role === 'admin') { %>
                        <a href="/add-movie" class="add-movie-btn">+ Add Movie</a>
                    <% } %>
                    <a href="/logout" class="logout-btn">Logout</a>
                    <span class="welcome-text">Hi, <%= user.username %></span>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                <% } %>
            </div>
        </div>
    </header>

    <div class="hero">
        <div class="hero-content">
            <h1>Unlimited Movies,<br>Anywhere, Anytime</h1>
            <p>Watch your favorite movies instantly. Stream on any device, no limits.</p>
            <button class="btn-primary" id="browseMoviesBtn">Browse Movies</button>
        </div>
    </div>

    <div class="main-content" id="movies-section">
        <% if (error) { %>
            <div class="error-message" style="background:#e50914dd; padding:14px; border-radius:60px; margin-bottom:32px; text-align:center;"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="success-message" style="background:#2e7d32dd; padding:14px; border-radius:60px; margin-bottom:32px; text-align:center;"><%= success %></div>
        <% } %>

        <div class="category-bar">
            <div class="category-scroll-wrapper">
                <div class="category-scroll" id="categoryScrollContainer"></div>
            </div>
            <div class="dropdown-container">
                <button class="dropdown-circle-btn" id="dropdownBtn" aria-label="Search categories">
                    <i class="fas fa-search"></i>
                </button>
                <div class="dropdown-menu" id="dropdownMenu">
                    <div class="dropdown-header">
                        <h4><i class="fas fa-tags"></i> Search Categories</h4>
                        <div class="dropdown-search">
                            <i class="fas fa-search"></i>
                            <input type="text" id="dropdownSearchInput" placeholder="Type to search..." autocomplete="off">
                        </div>
                    </div>
                    <div class="dropdown-categories" id="dropdownCategoriesList"></div>
                </div>
            </div>
        </div>

        <div class="category-section" id="trendingSection">
            <div class="section-header">
                <h2 class="section-title">🔥 Trending Now</h2>
                <span class="section-count" id="trendingCount">0 titles</span>
            </div>
            <div class="movies-row" id="trendingRow"></div>
        </div>

        <div id="dynamicCategoriesContainer"></div>
    </div>

    <footer class="footer">
        <p>© 2025 Movie Player. All rights reserved.</p>
        <p style="margin-top: 8px;">Stream your favorite movies anytime, anywhere — Cinematic Experience</p>
    </footer>

    <script>
        const ALL_CATEGORIES = [
            "Action", "Adventure", "Sci-Fi", "Thriller", "Horror", "Comedy", "Drama", "Romance", "Fantasy",
            "Netflix Originals", "Amazon Prime Exclusive", "Apple TV+", "HBO Max Originals", "Hulu Picks",
            "Bollywood", "South Indian Cinema", "Punjabi Films", "Indian Indie", "Anime", "Korean Drama", "K-Movie",
            "European Cinema", "Spanish Thriller", "French New Wave", "Documentary", "Biopic", "Crime", "Mystery",
            "Superhero", "Marvel/DC", "Animation", "Family", "Musical", "Western", "Cult Classics", "Oscar Winners",
            "Film Noir", "Psychological Thriller", "Sitcom", "Stand-up Special", "Reality TV", "War", "History",
            "Sports", "Teen Drama", "Coming of Age", "LGBTQ+", "Experimental", "Silent Era", "Zombie", "Vampire",
            "Cyberpunk", "Steampunk", "Apocalyptic", "Kaiju", "Wuxia", "Martial Arts", "Gangster", "Heist",
            "Courtroom Drama", "Political Thriller", "Rom-Com", "Dark Comedy", "Mockumentary", "Road Movie",
            "Holiday", "Christmas Special", "Nature", "Space Opera", "Time Travel", "Alternate History",
            "Streaming Exclusive", "Trending Now", "Binge-Worthy", "Critics' Pick", "Audience Favorite"
        ];

        let allMovies = [];
        try {
            const movieList = [];
            <% if (groupedMovies) { %>
                <% for (const [cat, movies] of Object.entries(groupedMovies)) { %>
                    <% movies.forEach(m => { 
                        const movieName = String(m.movieName || 'Untitled').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                        const posterUrl = String(m.posterUrl || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                        const movieUrl = String(m.movieUrl || '#').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                        const tag = String(m.tag || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
                        const priority = m.priority || 0;
                        const movieId = String(m._id || '');
                    %>
                        movieList.push({
                            _id: "<%= movieId %>",
                            movieName: `<%- movieName %>`,
                            posterUrl: `<%- posterUrl %>`,
                            movieUrl: `<%- movieUrl %>`,
                            priority: <%= priority %>,
                            tag: `<%- tag %>`,
                            category: `<%- cat.replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>`
                        });
                    <% }); %>
                <% } %>
            <% } %>
            allMovies = movieList;
        } catch(e) { 
            console.warn('Error loading movies:', e); 
            allMovies = []; 
        }

        let currentFilterCategory = 'all';
        let dropdownSearchTerm = '';

        function escapeHtml(str) { 
            if(!str) return ''; 
            return String(str).replace(/[&<>]/g, function(m){
                if(m === '&') return '&amp;';
                if(m === '<') return '&lt;';
                if(m === '>') return '&gt;';
                return m;
            });
        }

        function escapeAttr(str) { 
            if(!str) return '';
            return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); 
        }

        const isAdminUser = <%= (user && user.role === 'admin') ? 'true' : 'false' %>;

        function renderMovieCard(movie, isAdmin) {
            const posterHtml = movie.posterUrl && movie.posterUrl !== '' 
                ? `<img src="${escapeHtml(movie.posterUrl)}" alt="${escapeHtml(movie.movieName)}" loading="lazy" onerror="this.onerror=null; this.parentElement.innerHTML='<div class=placeholder>🎬<br><span style=font-size:0.7rem;>No Poster</span></div>'">`
                : `<div class="placeholder">🎬<br><span style="font-size: 0.7rem;">No Poster</span></div>`;
            
            const adminDeleteBtn = isAdmin ? 
                `<form action="/movie/${movie._id}?_method=DELETE" method="POST" style="display: inline;" onsubmit="return confirm('Remove this movie?')">
                    <button type="submit" class="delete-btn">✕ Remove</button>
                </form>` : '';
            
            return `
                <div class="movie-card">
                    <div class="movie-poster">
                        ${posterHtml}
                        <div class="priority-badge">PRIORITY ${movie.priority}</div>
                        ${adminDeleteBtn}
                    </div>
                    <div class="movie-info">
                        <div class="movie-name" title="${escapeHtml(movie.movieName)}">${escapeHtml(movie.movieName)}</div>
                        ${movie.tag ? `<div class="tag">#${escapeHtml(movie.tag)}</div>` : ''}
                        <a href="${escapeHtml(movie.movieUrl)}" class="movie-link" target="_blank" rel="noopener noreferrer">Watch Now →</a>
                    </div>
                </div>
            `;
        }

        function getTrendingMovies() {
            return [...allMovies]
            .sort((a,b) => b.priority - a.priority)
            .slice(0, 10);
        }

        function getAllCategoriesWithMovies() {
            const catMap = new Map();
            allMovies.forEach(movie => {
                const cat = movie.category || "Uncategorized";
                if (!catMap.has(cat)) catMap.set(cat, []);
                catMap.get(cat).push(movie);
            });
            return Array.from(catMap.entries()).map(([name, movies]) => ({ name, movies })).sort((a,b) => a.name.localeCompare(b.name));
        }

        function renderAllCategorySections() {
            const container = document.getElementById('dynamicCategoriesContainer');
            if (!container) return;
            const categoriesData = getAllCategoriesWithMovies();
            if (categoriesData.length === 0) {
                container.innerHTML = `<div class="empty-state"><div style="font-size:3rem;">🎬✨</div><h3>No Movies Found</h3><p>Add some movies to see categories</p></div>`;
                return;
            }
            let html = '';
            categoriesData.forEach(cat => {
                if (cat.movies.length === 0) return;
                html += `
                    <div class="category-section" data-category-name="${escapeHtml(cat.name)}">
                        <div class="section-header">
                            <h2 class="section-title">${escapeHtml(cat.name)}</h2>
                            <span class="section-count">${cat.movies.length} titles</span>
                        </div>
                        <div class="movies-row">
                            ${cat.movies.map(movie => renderMovieCard(movie, isAdminUser)).join('')}
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        function renderTrendingSection() {
            const trendingMovies = getTrendingMovies();
            const trendingRow = document.getElementById('trendingRow');
            const trendingCountSpan = document.getElementById('trendingCount');
            if (trendingRow) {
                if (trendingMovies.length === 0) {
                    trendingRow.innerHTML = `<div style="padding:40px; text-align:center; width:100%; color:#888;">No trending movies available</div>`;
                    if(trendingCountSpan) trendingCountSpan.innerText = '0 titles';
                } else {
                    trendingRow.innerHTML = trendingMovies.map(m => renderMovieCard(m, isAdminUser)).join('');
                    if(trendingCountSpan) trendingCountSpan.innerText = `${trendingMovies.length} titles`;
                }
            }
        }
        
        function filterMoviesByCategory(categoryName) {
            currentFilterCategory = categoryName;
            const container = document.getElementById('dynamicCategoriesContainer');
            if (!container) return;
            if (categoryName === 'all') {
                renderAllCategorySections();
            } else {
                const filteredMovies = allMovies.filter(m => (m.category || "Uncategorized") === categoryName);
                if (filteredMovies.length === 0) {
                    container.innerHTML = `<div class="empty-state"><div style="font-size:2.5rem;">🎬🔍</div><h3>No movies in "${escapeHtml(categoryName)}"</h3><p>Check back later for new additions</p></div>`;
                } else {
                    container.innerHTML = `
                        <div class="category-section">
                            <div class="section-header">
                                <h2 class="section-title">${escapeHtml(categoryName)} Movies</h2>
                                <span class="section-count">${filteredMovies.length} titles</span>
                            </div>
                            <div class="movies-row">
                                ${filteredMovies.map(m => renderMovieCard(m, isAdminUser)).join('')}
                            </div>
                        </div>
                    `;
                }
            }
            updateActiveChip(categoryName);
        }
        
        function updateActiveChip(categoryName) {
            document.querySelectorAll('.cat-chip').forEach(chip => {
                const catVal = chip.getAttribute('data-category');
                if ((catVal === categoryName) || (categoryName === 'all' && catVal === 'all')) {
                    chip.classList.add('active');
                } else {
                    chip.classList.remove('active');
                }
            });
        }
        
        function buildHorizontalCategories() {
            const container = document.getElementById('categoryScrollContainer');
            if (!container) return;
            let chipsHtml = `<div class="cat-chip active" data-category="all">🎬 All Movies</div>`;
            ALL_CATEGORIES.forEach(cat => {
                chipsHtml += `<div class="cat-chip" data-category="${escapeAttr(cat)}">${escapeHtml(cat)}</div>`;
            });
            container.innerHTML = chipsHtml;
            updateActiveChip(currentFilterCategory);
            document.querySelectorAll('.cat-chip').forEach(chip => {
                chip.addEventListener('click', function(e) {
                    filterMoviesByCategory(this.getAttribute('data-category'));
                    closeDropdown();
                });
            });
        }
        
        function buildDropdownCategories(searchTerm = '') {
            const container = document.getElementById('dropdownCategoriesList');
            if (!container) return;
            let filteredCategories = [...new Set(ALL_CATEGORIES)];
            if (searchTerm) filteredCategories = filteredCategories.filter(cat => cat.toLowerCase().includes(searchTerm.toLowerCase()));
            if (filteredCategories.length === 0) {
                container.innerHTML = `<div style="padding: 20px; text-align: center; color: #888;">No categories found</div>`;
                return;
            }
            let html = '';
            filteredCategories.forEach(cat => {
                html += `<div class="dropdown-cat-item ${currentFilterCategory === cat ? 'active' : ''}" data-category="${escapeAttr(cat)}"><i class="fas fa-tag"></i><span>${escapeHtml(cat)}</span></div>`;
            });
            container.innerHTML = html;
            document.querySelectorAll('.dropdown-cat-item').forEach(item => {
                item.addEventListener('click', function() {
                    filterMoviesByCategory(this.getAttribute('data-category'));
                    closeDropdown();
                    const targetChip = document.querySelector(`.cat-chip[data-category="${escapeAttr(this.getAttribute('data-category'))}"]`);
                    if (targetChip) targetChip.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                });
            });
        }
        
        function toggleDropdown() {
            const menu = document.getElementById('dropdownMenu');
            const btn = document.getElementById('dropdownBtn');
            menu.classList.toggle('show');
            btn.classList.toggle('active');
            if (menu.classList.contains('show')) {
                buildDropdownCategories(dropdownSearchTerm);
                document.getElementById('dropdownSearchInput').focus();
            }
        }
        
        function closeDropdown() {
            const menu = document.getElementById('dropdownMenu');
            const btn = document.getElementById('dropdownBtn');
            if(menu) menu.classList.remove('show');
            if(btn) btn.classList.remove('active');
        }
        
        function initDropdownSearch() {
            const searchInput = document.getElementById('dropdownSearchInput');
            if(searchInput) {
                searchInput.addEventListener('input', function(e) {
                    dropdownSearchTerm = e.target.value;
                    buildDropdownCategories(dropdownSearchTerm);
                });
            }
        }
        
        function init() {
            renderTrendingSection();
            buildHorizontalCategories();
            renderAllCategorySections();
            const dropdownBtn = document.getElementById('dropdownBtn');
            if(dropdownBtn) dropdownBtn.addEventListener('click', toggleDropdown);
            document.addEventListener('click', function(e) {
                const menu = document.getElementById('dropdownMenu');
                const btn = document.getElementById('dropdownBtn');
                if(menu && btn && !btn.contains(e.target) && !menu.contains(e.target)) closeDropdown();
            });
            initDropdownSearch();
            window.addEventListener('scroll', function() {
                const header = document.getElementById('header');
                if (window.scrollY > 80) header.classList.add('scrolled');
                else header.classList.remove('scrolled');
            });
            const browseBtns = document.querySelectorAll('#browseMoviesBtn, #browseMoviesLink');
            browseBtns.forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const moviesSection = document.getElementById('movies-section');
                    if(moviesSection) window.scrollTo({ top: moviesSection.getBoundingClientRect().top + window.pageYOffset - 80, behavior: 'smooth' });
                });
            });
            const logoHome = document.getElementById('logoHomeBtn');
            if(logoHome) logoHome.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
            window.addEventListener('scroll', function() {
                const heroSection = document.querySelector('.hero');
                if (heroSection && window.scrollY <= window.innerHeight) {
                    heroSection.style.backgroundPosition = `center ${30 + window.scrollY * 0.05}%`;
                }
            });
        }
        
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
    </script>
</body>
</html>