<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎬 Movie Collection</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 50px;
            animation: fadeInDown 0.8s ease;
        }

        .header h1 {
            font-size: 3rem;
            color: white;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
            margin-bottom: 10px;
        }

        .header p {
            color: rgba(255,255,255,0.9);
            font-size: 1.2rem;
        }

        .movie-count {
            background: rgba(255,255,255,0.2);
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            margin-top: 15px;
            font-size: 0.9rem;
        }

        .error-message {
            background: #f44336;
            color: white;
            padding: 15px 25px;
            border-radius: 10px;
            margin-bottom: 30px;
            text-align: center;
            animation: shake 0.5s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .error-message a {
            color: white;
            text-decoration: underline;
        }

        .movie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            animation: fadeInUp 0.8s ease;
        }

        .movie-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .movie-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        .movie-poster {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .movie-icon {
            font-size: 4rem;
        }

        .movie-info {
            padding: 20px;
        }

        .movie-title {
            font-size: 1.3rem;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .movie-year {
            color: #667eea;
            font-size: 0.9rem;
            font-weight: normal;
        }

        .movie-rating {
            color: #ffc107;
            margin: 10px 0;
            font-size: 0.9rem;
        }

        .movie-link {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: transform 0.2s ease;
            text-align: center;
            width: 100%;
            font-weight: 500;
        }

        .movie-link:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            background: white;
            border-radius: 15px;
            animation: fadeIn 0.8s ease;
        }

        .empty-state .emoji {
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: #333;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: #666;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
            20%, 40%, 60%, 80% { transform: translateX(5px); }
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 2rem;
            }
            
            .movie-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            body {
                padding: 20px 15px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎬 Movie Collection</h1>
            <p>Discover and explore amazing movies</p>
            <% if (movies.length > 0) { %>
                <div class="movie-count">📽️ <%= movies.length %> movies available</div>
            <% } %>
        </div>

        <% if (error) { %>
            <div class="error-message">
                ⚠️ <%= error %>
                <br><br>
                <small>To fix this: Go to MongoDB Atlas → Network Access → Add IP Address → Add 0.0.0.0/0 (allow all) or add Render.com IP ranges</small>
            </div>
        <% } %>

        <% if (movies && movies.length > 0) { %>
            <div class="movie-grid">
                <% movies.forEach((movie) => { %>
                    <div class="movie-card">
                        <div class="movie-poster">
                            <div class="movie-icon">🎥</div>
                        </div>
                        <div class="movie-info">
                            <div class="movie-title">
                                <%= movie.name %>
                                <% if (movie.year) { %>
                                    <span class="movie-year">(<%= movie.year %>)</span>
                                <% } %>
                            </div>
                            <% if (movie.rating) { %>
                                <div class="movie-rating">
                                    ⭐ <%= movie.rating %> / 10
                                </div>
                            <% } %>
                            <a href="<%= movie.link %>" class="movie-link" target="_blank" rel="noopener noreferrer">
                                Watch Now ▶
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else if (!error) { %>
            <div class="empty-state">
                <div class="emoji">🍿</div>
                <h3>No movies found</h3>
                <p>Add some movies to your collection to get started!</p>
            </div>
        <% } %>
    </div>
</body>
</html>